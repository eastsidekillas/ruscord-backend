DJANGO_ENV=dev  # dev | prod

DJANGO_SECRET_KEY=replace-me-with-a-secure-random-string

CORS_ALLOWED_ORIGINS=http://localhost:4200
CSRF_TRUSTED_ORIGINS=http://localhost:4200

# --- База данных ---
# SQLite (dev):
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# PostgreSQL (prod):
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=ruscord
# DATABASE_USER=ruscord
# DATABASE_PASSWORD=ruscord
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# --- Redis ---
REDIS_HOST=localhost   # в Docker: redis
REDIS_PORT=6379
REDIS_DB=0

# --- LiveKit ---
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# --- Медиафайлы ---
MEDIA_ROOT=media
MEDIA_URL=media/

# --- Только для prod ---
# PUBLIC_HOST=ruscord.click
# STATIC_ROOT=/app/static